@model SakuraWeb.Models.Rezervacija

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Rezervacija</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="datumRezervacije" class="control-label"></label>
                <input asp-for="datumRezervacije" class="form-control" />
                <span asp-validation-for="datumRezervacije" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="vrijemeTermina" class="control-label"></label>
                <input asp-for="vrijemeTermina" class="form-control" />
                <span asp-validation-for="vrijemeTermina" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="otkazana" /> @Html.DisplayNameFor(model => model.otkazana)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="ocjena" class="control-label"></label>
                <input asp-for="ocjena" class="form-control" />
                <span asp-validation-for="ocjena" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="korisnikId" class="control-label"></label>
                <select asp-for="korisnikId" class ="form-control" asp-items="ViewBag.korisnikId"></select>
            </div>
            <div class="form-group">
                <label asp-for="uslugaId" class="control-label"></label>
                <select asp-for="uslugaId" class ="form-control" asp-items="ViewBag.uslugaId"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
